{
  "ConnectionStrings": {
    "DefaultConnection": "Host=YOUR_DB_HOST;Database=planca;Username=YOUR_DB_USER;Password=YOUR_DB_PASSWORD;SSL Mode=Require;Trust Server Certificate=true;"
  },
  "CacheSettings": {
    "ConnectionString": "",
    "InstanceName": "Planca_",
    "DefaultExpirationMinutes": 30,
    "EnableDistributedCache": true,
    "EnableResponseCaching": true
  },
  "JwtSettings": {
    "Key": "YOUR_JWT_SECRET_KEY_AT_LEAST_256_BITS",
    "EncryptedKey": "YOUR_ENCRYPTED_KEY",
    "Issuer": "PlancaAPI",
    "Audience": "PlancaClient",
    "DurationInMinutes": 30,
    "RefreshTokenDurationInDays": 7
  },
  "Cors": {
    "Origins": ["https://YOUR_FRONTEND_URL"]
  },
  "DataRetention": {
    "PurgeAfter": "30.00:00:00",
    "ArchiveAfter": "15.00:00:00",
    "AutoPurgeEnabled": false,
    "PurgeIntervalMinutes": 1440
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
